<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Notes</title>
        <link rel="stylesheet" href="/styles_notes.css">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        <script defer src="https://cdn.vercel-insights.com/v1/script.js"></script>
    </head>
    <body>
        <nav>
            <div class="profile-menu-container">
                <div class="profile-trigger" onclick="toggleMenu()">
                    <% if (user.picture) { %>
                        <img src="<%= user.picture %>" alt="Profile Picture" class="profile-pic">
                    <% } else { %>
                        <div class="profile-placeholder"><%= user.email.charAt(0).toUpperCase() %></div>
                    <% } %>
                    
                    <span class="user-name"><%= user.name || user.email.split('@')[0] %></span>
                    <span class="dropdown-arrow">▼</span>
                </div>
                
                <div id="dropdown-menu" class="dropdown-content hidden">
                    <button id="logout-btn" onclick="window.location.href='/logout'">Logout</button>
                </div>
            </div>
        </nav>
        <main>
            <form action="/notes/search" method="GET">
                <input type="text" name="q" placeholder="Search notes...">
                <button type="submit">🔍Search</button>
            </form>
            <ul class="notes-list">
                <% for(let i=0; i<notes.length; i++){ %>
                <li class="note">
                    <button onclick="window.location.href='/notes/<%= notes[i].id %>'">
                        <h2><%= notes[i].title %></h2>
                        <p><%= notes[i].note.replace(/<[^>]*>?/gm, '').slice(0, 20) %>...</p>
                    </button>
                </li>
                <% } %>
                <% if(notes.length === 0){ %>
                    <p>No notes found. Click the + button to create a new note.</p>
                <% } %>
            </ul>
        </main>

        <button class="add-note-btn" onclick="window.location.href='/notes/new'" aria-label="Create new note">
            +
        </button>
        <script>
            function toggleMenu() {
                const menu = document.getElementById('dropdown-menu');
                menu.classList.toggle('hidden');
            }

            window.onclick = function(event) {
                if (!event.target.closest('.profile-menu-container')) {
                    const menu = document.getElementById('dropdown-menu');
                    if (!menu.classList.contains('hidden')) {
                        menu.classList.add('hidden');
                    }
                }
            }
        </script>
    </body>
</html>
